# ─── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key (server-only, NEVER exposed to browser).
# Used by the reservation API and accept/refuse webhook to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public URL of the deployed site. Used to build the accept/refuse links
# sent over WhatsApp. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://maison-r.vercel.app

# ─── Twilio (WhatsApp notifications to the owner) ──────────────────────────
# Create a Twilio account, enable the WhatsApp sandbox or a Business sender,
# then fill these three.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=+14155238886
