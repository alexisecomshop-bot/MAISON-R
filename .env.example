# ─── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key (server-only, NEVER exposed to browser).
# Used by the reservation API and accept/refuse webhook to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public URL of the deployed site. Used to build the accept/refuse links
# sent over WhatsApp. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://maison-r.vercel.app

# ─── Google Sheet → catalogue sync ─────────────────────────────────────────
# Publish the sheet as CSV: File → Share → Publish to web → CSV.
# Paste the URL Google gives you here.
GOOGLE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/e/XXXXXX/pub?output=csv

# Shared secret to authorize sync calls (random 32+ chars).
# Must also be set as a GitHub Actions secret named SYNC_SECRET.
SYNC_SECRET=change-me-to-a-random-string

# ─── Twilio (WhatsApp notifications to the owner) ──────────────────────────
# Create a Twilio account, enable the WhatsApp sandbox or a Business sender,
# then fill these three.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=+14155238886

# Owner WhatsApp number (E.164 format with country code, no spaces).
# Used as fallback when no number is set in the admin panel.
# Example for France: +33XXXXXXXXX (replace the leading 0).
OWNER_WHATSAPP=+33XXXXXXXXX
